# Slack Bot Token (Bot User OAuth Token - starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App Token (Socket Mode - starts with xapp-)
SLACK_APP_TOKEN=xapp-your-app-token

# Path to modelopt_agent repo root (where .claude/skills/ lives)
# Defaults to parent directory of slack-bot/
# SKILLS_CWD=/path/to/modelopt_agent
